[Unit]
Description=FPREN Network Monitor — email alert on ETH/WiFi state change
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/ufuser/scripts/network_monitor.py
Restart=on-failure
RestartSec=10

StandardOutput=append:/home/ufuser/weather_station/logs/network_monitor.log
StandardError=append:/home/ufuser/weather_station/logs/network_monitor.log

[Install]
WantedBy=default.target
