[Unit]
Description=FPREN Alarm Engine — central alarm processor and notifier
After=network.target mongod.service
Wants=mongod.service

[Service]
Type=simple
User=ufuser
WorkingDirectory=/home/ufuser/Fpren-main/fpren-agents/alarm_system
ExecStart=/home/ufuser/Fpren-main/venv/bin/python3 alarm_engine.py
Restart=on-failure
RestartSec=10
Environment=MONGO_URI=mongodb://localhost:27017
EnvironmentFile=-/home/ufuser/Fpren-main/weather_station/.env

[Install]
WantedBy=multi-user.target
