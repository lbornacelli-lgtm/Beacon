[Unit]
Description=Beacon IPAWS Fetcher — FEMA emergency alerts
After=network.target mongod.service
Wants=mongod.service

[Service]
Type=simple
User=ufuser
WorkingDirectory=/home/ufuser/Downloads/Beacon-main/weather_rss
ExecStart=/home/ufuser/Downloads/Beacon-main/venv/bin/python3 ipaws_fetcher.py
Restart=on-failure
RestartSec=10
Environment=MONGO_URI=mongodb://localhost:27017
Environment=LOG_FILE=/home/ufuser/Downloads/Beacon-main/weather_rss/logs/ipaws.log

[Install]
WantedBy=multi-user.target
